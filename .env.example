# Base de datos
DATABASE_URL="postgresql://user:password@host:5432/inventario?schema=public"

# NextAuth
NEXTAUTH_URL="https://tu-dominio.railway.app"
NEXTAUTH_SECRET="genera-con-openssl-rand-base64-32"

# Resend (correo)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="inventario@tudominio.com"

# Telegram Bot
TELEGRAM_BOT_TOKEN="123456789:ABCDefghijk..."
TELEGRAM_WEBHOOK_URL="https://tu-dominio.railway.app/api/notificaciones/telegram/webhook"

# Cloudinary
CLOUDINARY_CLOUD_NAME="tu-cloud-name"
CLOUDINARY_API_KEY="123456789012345"
CLOUDINARY_API_SECRET="tu-api-secret"

# App
NEXT_PUBLIC_APP_URL="https://tu-dominio.railway.app"
NEXT_PUBLIC_APP_NAME="InventaPro"
NODE_ENV="production"
